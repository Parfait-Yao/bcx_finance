DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bcx_finance?schema=public"

# JWT — générez des chaînes aléatoires longues et différentes en production
JWT_ACCESS_SECRET="change_this_access_secret_in_production"
JWT_REFRESH_SECRET="change_this_refresh_secret_in_production"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# App
PORT=3001
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# IA (optionnel) : conseils/alertes personnalisés sur le Score BCX.
# Si vide, un message de repli basé sur des règles est utilisé à la place.
ANTHROPIC_API_KEY=""

# Email (optionnel) : envoi du lien de réinitialisation de mot de passe.
# Si SMTP_HOST est vide, le lien est simplement affiché dans les logs du
# serveur (utile en développement).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BCX Finance <no-reply@bcxfinance.com>"
