// Schéma Prisma - BCX Finance
// Base de données : PostgreSQL 16

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TypeTransaction {
  recette
  depense
}

enum NiveauInsight {
  bon
  attention
  critique
}

model User {
  id            String   @id @default(uuid())
  nom           String
  telephone     String   @unique
  email         String   @unique
  entreprise    String
  motDePasse    String   @map("mot_de_passe")
  ville         String
  pays          String   @default("Côte d'Ivoire")
  scoreBcx      Int      @default(0) @map("score_bcx")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  transactions  Transaction[]
  reports       Report[]
  notifications Notification[]
  passwordResets PasswordReset[]

  @@index([telephone])
  @@index([email])
  @@map("users")
}

// Jeton de réinitialisation de mot de passe.
// Sécurité : seul le HASH du jeton est stocké (jamais le jeton en clair),
// le jeton expire après 15 minutes et est supprimé après usage (à usage
// unique). Un voleur de la base de données ne peut donc pas l'utiliser
// pour réinitialiser un mot de passe.
model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model Category {
  id        String           @id @default(uuid())
  nom       String
  type      TypeTransaction
  emoji     String
  createdAt DateTime         @default(now()) @map("created_at")

  transactions Transaction[]

  @@index([type])
  @@map("categories")
}

model Transaction {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  categorieId     String?          @map("categorie_id")
  type            TypeTransaction
  montant         Decimal          @db.Decimal(15, 2)
  description     String?          @db.Text
  dateTransaction DateTime         @map("date_transaction") @db.Date
  createdAt       DateTime         @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categorie Category? @relation(fields: [categorieId], references: [id], onDelete: SetNull)

  @@index([userId, dateTransaction])
  @@index([userId, type])
  @@map("transactions")
}

model Report {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  mois           Int
  annee          Int
  totalRecettes  Decimal  @map("total_recettes") @db.Decimal(15, 2)
  totalDepenses  Decimal  @map("total_depenses") @db.Decimal(15, 2)
  soldeNet       Decimal  @map("solde_net") @db.Decimal(15, 2)
  scoreBcx       Int      @map("score_bcx")
  joursSaisie    Int      @map("jours_saisie")
  fichierPdf     String?  @map("fichier_pdf")
  createdAt      DateTime @default(now()) @map("created_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights ReportInsight[]

  @@unique([userId, mois, annee])
  @@index([userId, annee, mois])
  @@map("reports")
}

model ReportInsight {
  id        String        @id @default(uuid())
  reportId  String        @map("report_id")
  type      String
  niveau    NiveauInsight
  message   String        @db.Text
  createdAt DateTime      @default(now()) @map("created_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_insights")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  message   String   @db.Text
  lu        Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lu])
  @@map("notifications")
}
